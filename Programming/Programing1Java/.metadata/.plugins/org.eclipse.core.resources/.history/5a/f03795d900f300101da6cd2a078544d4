package firstJavaProgams;

import java.util.Scanner;

public class ArithmeticProgram {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		
		System.out.print("Enter an integer: ");
		int firstInt = Integer.parseInt(input.nextLine());
		
		System.out.print("Enter another integer: ");
		int secondInt = Integer.parseInt(input.nextLine());
		
		System.out.print("Enter a decimal number: ");
		double d = Double.parseDouble(input.nextLine().replace(',', '.'));
		
		int result1 = firstInt * secondInt;
		double result2 = firstInt * d;
		double result3 = secondInt * d;
		
		System.out.println();
		System.out.println(firstInt + " * " + secondInt + " = " + result1);
		System.out.println(firstInt + " * " + d + " = " + result2);
		System.out.println(secondInt + " * " + d + " = " + result3);
		
	}

}
