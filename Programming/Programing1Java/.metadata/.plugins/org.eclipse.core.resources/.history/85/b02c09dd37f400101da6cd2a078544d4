package basicCalculations;

import java.util.Scanner;
import java.text.DecimalFormat;
import java.text.DecimalFormatSymbols;

public class MultiplicationProgram {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		DecimalFormatSymbols symbol = new DecimalFormatSymbols();
		symbol.setDecimalSeparator('.');
		DecimalFormat twoDecimals = new DecimalFormat("0.00", symbol);
		
		System.out.print("Enter x: ");
		double x = Double.parseDouble(input.nextLine().trim().replace(',', '.'));
		
		System.out.print("Enter y: ");
		double y = Double.parseDouble(input.nextLine().trim().replace(',', '.'));
		
		double product = x * y;
		
		String result = x + " * " + y + " = " + twoDecimals.format(product);
		
		System.out.println();
		System.out.println(result);
					
	}

}

