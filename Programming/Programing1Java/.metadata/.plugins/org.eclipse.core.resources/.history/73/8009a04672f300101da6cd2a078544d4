package firstJavaProgams;

import java.util.Scanner;
import java.text.DecimalFormat;
import java.text.DecimalFormatSymbols;

public class DecimalProgram {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		
		System.out.print("Enter a decimal number: ");
		String rawA = input.nextLine().trim();
		double a = Double.parseDouble(rawA.replace(',', '.'));
		
		System.out.print("Enter a decimal number: ");
		String rawB = input.nextLine().trim();
		double b = Double.parseDouble(rawB.replace(',', '.'));
		
		double c = a * b;
		DecimalFormatSymbols symbol = new DecimalFormatSymbols();
		symbol.setDecimalSeparator(',');
		DecimalFormat twoDecimals = new DecimalFormat("0.00", symbol);
		DecimalFormat sixDecimals = new DecimalFormat("0.000000", symbol);
		
		String aFormatted = rawA.replace('.', ',');
		String bFormatted = rawB.replace('.', ',');
		
		System.out.println();
		System.out.println(aFormatted + " * " + bFormatted + " = " + twoDecimals.format(c));
		System.out.println(aFormatted + " * " + bFormatted + " = " + sixDecimals.format(c));
		
	}

}
