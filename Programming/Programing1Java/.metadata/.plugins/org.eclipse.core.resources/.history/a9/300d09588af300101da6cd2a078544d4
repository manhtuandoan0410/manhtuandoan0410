package basicCalculations;

import java.util.Scanner;
import java.text.DecimalFormat;
import java.text.DecimalFormatSymbols;

public class TrainTravel {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		DecimalFormatSymbols symbol = new DecimalFormatSymbols();
		symbol.setDecimalSeparator(',');
		DecimalFormat twoDecimals = new DecimalFormat("0.00", symbol);
		
		System.out.print("Enter the number of train trips: ");
		int trips = Integer.parseInt(input.nextLine().trim());
		
		System.out.print("Enter the single ticket price: ");
		double ticketPrice = Double.parseDouble(input.nextLine().trim().replace(',', '.'));
		
		System.out.print("Enter the monthly season ticket price: ");
		double seasonPrice = Double.parseDouble(input.nextLine().trim().replace(',', '.'));
		
		double totalTripsCost = (double) trips * ticketPrice;
		double singleCheaper = seasonPrice - totalTripsCost;
		double seasonCheaper = totalTripsCost - seasonPrice;
		
		if (totalTripsCost < seasonPrice) {
			System.out.println("Buying single tickets is " + singleCheaper + " euros cheaper.");
		} else if (seasonPrice < totalTripsCost){
			System.out.println("Buying a monthly season ticket is " + seasonCheaper + " euros cheaper.");
		} else {
			System.out.println("The total cost is the same");
		}
		
	}

}
