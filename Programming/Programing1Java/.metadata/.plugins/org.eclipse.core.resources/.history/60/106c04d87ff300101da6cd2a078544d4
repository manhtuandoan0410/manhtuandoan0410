package basicCalculations;

import java.util.Scanner;
import java.text.DecimalFormat;
import java.text.DecimalFormatSymbols;

public class PopulationProgram {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		DecimalFormatSymbols symbol = new DecimalFormatSymbols();
		symbol.setDecimalSeparator(',');
		DecimalFormat oneDecimal = new DecimalFormat("0.0", symbol);
		
		System.out.print("Enter the population of the area A: ");
		int popA = Integer.parseInt(input.nextLine().trim().replace(',', '.'));
		
		System.out.print("Enter the population of the area B: ");
		int popB = Integer.parseInt(input.nextLine().trim().replace(',', '.'));
		
		System.out.print("Enter the population of the area C: ");
		int popC = Integer.parseInt(input.nextLine().trim().replace(',', '.'));
		
		int totalPop = popA + popB + popC;
		double perA = popA / totalPop * 100;
		double perB = popB / totalPop * 100;
		double perC = popC / totalPop * 100;
		
		String resultA = "A: " + oneDecimal.format(perA) + " %";
		String resultB = "B: " + oneDecimal.format(perB) + " %";
		String resultC = "C: " + oneDecimal.format(perC) + " %";
		
		System.out.println();
		System.out.println(resultA);
		System.out.println(resultB);
		System.out.println(resultC);
		
	}

}
