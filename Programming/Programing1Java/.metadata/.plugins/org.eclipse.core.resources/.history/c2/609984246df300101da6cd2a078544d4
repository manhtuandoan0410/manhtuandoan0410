package firstJavaProgams;

import java.util.Scanner;
import java.text.DecimalFormat;

public class DecimalProgram {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner input = new Scanner(System.in);
		
		System.out.print("Enter a decimal number: ");
		double a = Double.parseDouble(input.nextLine().replace(',', '.'));
		
		System.out.print("Enter a decimal number: ");
		double b = Double.parseDouble(input.nextLine().replace(',', '.'));
		
		double c = a * b;
		DecimalFormat twoDecimals = new DecimalFormat("0.00");
		DecimalFormat sixDecimals = new DecimalFormat("0.000000");
		
		System.out.println();
		System.out.println(a + " * " + b + " = " + twoDecimals.format(c));
		System.out.println(a + " * " + b + " = " + sixDecimals.format(c));
		
	}

}
