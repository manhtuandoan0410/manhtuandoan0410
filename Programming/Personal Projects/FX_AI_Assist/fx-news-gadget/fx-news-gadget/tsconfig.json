{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",                  // Modern JS output
    "lib": ["ES2020", "DOM"],            // Include DOM + modern JS APIs
    "module": "ESNext",                  // Use modern ES modules
    "moduleResolution": "Node",          // Node-style resolution
    "esModuleInterop": true,             // Allow default imports from CJS
    "allowSyntheticDefaultImports": true,// Smooth interop with JS libs
    "resolveJsonModule": true,           // Allow importing .json files
    "skipLibCheck": true,                // Skip type checks in node_modules

    /* Type Checking */
    "strict": true,                      // Enable all strict checks
    "noImplicitAny": true,               // Prevent implicit 'any'
    "forceConsistentCasingInFileNames": true,

    /* Output */
    "outDir": "./dist",                  // Compiled JS output
    "rootDir": "./src",                  // Source files
    "sourceMap": true,                   // Generate .map files for debugging

    /* Node.js specifics */
    "types": ["node"],                   // Include Node.js type definitions
    "allowJs": false                     // Only allow .ts files
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
